{
  "appTitle": "Conclave Story Experience",
  "clickThreshold": 10,
  "defaultFrustration": 0,
  "showBackgroundImage": true,
  "backgroundImage": "assets/images/ui/background.jpg",
  "ui": {
    "fontFamily": "\"Trebuchet MS\", \"Segoe UI\", sans-serif",
    "bodyLineHeight": 1.6,
    "titleLineHeight": 0.92,
    "titleSize": "clamp(2.4rem, 4vw, 4.35rem)",
    "bodyFontSize": "clamp(1rem, 1vw, 1.08rem)",
    "buttonFontSize": "clamp(0.98rem, 0.95vw, 1.05rem)",
    "buttonRadius": 18,
    "frameRadius": 30,
    "visualRadius": 24,
    "buttonGapRem": 0.82,
    "copyActionsGapRem": 1.05,
    "visualMaxWidth": 400,
    "visualMaxHeight": 560,
    "pageBackground": "#07111d",
    "panelBackground": "rgba(8, 18, 32, 0.8)",
    "textStrong": "#fff4e7",
    "textBody": "#d6e2f2",
    "textMuted": "#90a9c0",
    "borderSoft": "rgba(124, 185, 255, 0.18)",
    "borderStrong": "rgba(124, 185, 255, 0.38)",
    "buttonPrimaryBackground": "rgba(7, 22, 43, 0.9)",
    "buttonPrimaryText": "#edf5ff",
    "buttonSecondaryBackground": "rgba(7, 22, 43, 0.9)",
    "buttonSecondaryText": "#edf5ff",
    "meterTrack": "rgba(196, 223, 255, 0.16)",
    "meterFill": "linear-gradient(90deg, #7de7ff 0%, #ff9a62 100%)",
    "focusRing": "#ffd7a8",
    "shadowSoft": "0 36px 90px rgba(1, 8, 18, 0.56)",
    "transitionFast": "180ms cubic-bezier(0.2, 0.8, 0.2, 1)",
    "transitionMedium": "420ms cubic-bezier(0.2, 0.8, 0.2, 1)"
  },
  "enableAudio": true,
  "audioVolume": 0.32,
  "synthMusicVolume": 0.22,
  "audioToggleIcon": "assets/icons/audio-toggle.svg",
  "audioFiles": [
    {
      "src": "assets/audio/bg-loop.mp4",
      "type": "audio/mp4"
    },
    {
      "src": "assets/audio/optional-fallback.mp3",
      "type": "audio/mpeg"
    }
  ],
  "soundEffects": {
    "enabled": true,
    "masterVolume": 0.38,
    "clickVolume": 0.08,
    "transitionVolume": 0.06
  }
}
